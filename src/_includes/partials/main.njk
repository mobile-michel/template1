<main class="container">
    <div bp="grid">
        <div bp="4@md">
            <aside>
                <nav>
                    <ul>
                        {%- for post in collections.general -%}
                        <li><a href="{{ post.url }}">{{ post.data.title }}</a></li>
                        {%- endfor -%}
                    </ul>
                </nav>
            </aside>
        </div>
        <div bp="8@md">
            <h1>{{ title }}</h1>
            {{ content | safe }}
        </div>
    </div>
</main>